# Copy this file to .env and fill in your credentials
# Get them from your Supabase project settings → API

# ⚠️  Hanya gunakan VITE_SUPABASE_URL — BUKAN VITE_PUBLIC_SUPABASE_URL (deprecated, menyebabkan crash)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# z.ai / OpenAI-compatible API Key — simpan di Supabase Secrets, bukan di sini
# supabase secrets set OPENAI_API_KEY=sk-xxx OPENAI_BASE_URL=https://ai.sumopod.com/v1
VITE_MODEL=kimi-k2.6
